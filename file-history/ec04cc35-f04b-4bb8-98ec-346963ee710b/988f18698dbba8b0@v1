final RecordDefinitions<Role> roleRecords = RecordDefinitions<Role>(
  table: 'roles',
  data: [
    ...rolesSuperAdmin,
    ...rolesTeamAdmin,
    ...rolesTeamManager,
    ...rolesTeamMember,
    ...rolesPersonalUser,
