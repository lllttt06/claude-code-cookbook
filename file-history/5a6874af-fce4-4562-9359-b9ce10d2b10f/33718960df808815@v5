// Package imports:
import 'package:baseball_detector_flutter/data/models/user_info.dart';
import 'package:flutter_hooks_test/flutter_hooks_test.dart';
import 'package:flutter_test/flutter_test.dart';
import 'package:hooks_riverpod/hooks_riverpod.dart';

// Project imports:
import 'package:baseball_detector_flutter/controllers/team_list_controller.dart';
import 'package:baseball_detector_flutter/controllers/user_accessible_contents_controller.dart';
import 'package:baseball_detector_flutter/data/models/plan.dart';
import 'package:baseball_detector_flutter/data/models/session.dart';
import 'package:baseball_detector_flutter/data/models/team.dart';
import 'package:baseball_detector_flutter/data/models/team_plan.dart';
import 'package:baseball_detector_flutter/data/profile_storage_fake.dart';
import 'package:baseball_detector_flutter/data/result.dart';
import 'package:baseball_detector_flutter/providers/profile_storage_provider.dart';
import 'package:baseball_detector_flutter/views/pages/home/sessions/session_details/hooks/use_fab_state.dart';

void main() {
  group('useFabState', () {
    const testUserId = 'test-user-id';
    const testTeamId = 'test-team-id';
    final testSession = Session(
      id: 'session-1',
      userId: testUserId,
      teamId: testTeamId,
    );

    final mockProfileStorage = FakeProfileStorage(
      userId: testUserId,
      teamId: testTeamId,
    );
    final mockAccessibleContents = UserAccessibleContents(
      appRole: AppRole.teamAdmin,
      accessibleTeamIds: [testTeamId],
    );

    test('should return available when recording is available', () async {
      final team = Team(
        id: testTeamId,
        teamType: TeamType.single,
        teamPlan: TeamPlan(
          plan: const Plan(
            name: 'standard',
            maxBalls: 100,
          ),
          currentUsage: 50,
        ),
      );

      final result = await buildHook(
        () => useFabState(
          session: testSession,
          teamId: testTeamId,
          canSubscribe: true,
        ),
        wrapper: (child) => ProviderScope(
          overrides: [
            profileStorageProvider.overrideWithValue(mockProfileStorage),
            userAccessibleContentsControllerProvider
                .overrideWith((ref) => mockAccessibleContents),
            teamListControllerProvider.overrideWith(
              (ref) => AsyncValue.data([team]),
            ),
          ],
          child: child,
        ),
      );

      expect(result.current, FabState.available);
    });

    test('should return needsSubscription when not premium and cannot analyze',
        () async {
      final team = Team(
        id: testTeamId,
        teamType: TeamType.single,
        teamPlan: TeamPlan(
          plan: const Plan(
            name: 'standard',
            maxBalls: 100,
          ),
          currentUsage: 100, // reached limit
        ),
      );

      final result = await buildHook(
        () => useFabState(
          session: testSession,
          teamId: testTeamId,
          canSubscribe: true,
        ),
        wrapper: (child) => ProviderScope(
          overrides: [
            profileStorageProvider.overrideWithValue(mockProfileStorage),
            userAccessibleContentsControllerProvider
                .overrideWith((ref) => mockAccessibleContents),
            teamListControllerProvider.overrideWith(
              (ref) => AsyncValue.data([team]),
            ),
          ],
          child: child,
        ),
      );

      expect(result.current, FabState.needsSubscription);
    });

    test('should return unavailable when premium plan and reached limit',
        () async {
      final team = Team(
        id: testTeamId,
        teamType: TeamType.single,
        teamPlan: TeamPlan(
          plan: const Plan(
            name: 'premium',
            maxBalls: 1000,
          ),
          currentUsage: 1000, // reached limit
        ),
      );

      final result = await buildHook(
        () => useFabState(
          session: testSession,
          teamId: testTeamId,
          canSubscribe: true,
        ),
        wrapper: (child) => ProviderScope(
          overrides: [
            profileStorageProvider.overrideWithValue(mockProfileStorage),
            userAccessibleContentsControllerProvider
                .overrideWith((ref) => mockAccessibleContents),
            teamListControllerProvider.overrideWith(
              (ref) => AsyncValue.data([team]),
            ),
          ],
          child: child,
        ),
      );

      expect(result.current, FabState.unavailable);
    });

    test(
        'should return available when premium plan but still has remaining balls',
        () async {
      final team = Team(
        id: testTeamId,
        teamType: TeamType.single,
        teamPlan: TeamPlan(
          plan: const Plan(
            name: 'premium',
            maxBalls: 1000,
          ),
          currentUsage: 900, // approaching limit but not reached
        ),
      );

      final result = await buildHook(
        () => useFabState(
          session: testSession,
          teamId: testTeamId,
          canSubscribe: true,
        ),
        wrapper: (child) => ProviderScope(
          overrides: [
            profileStorageProvider.overrideWithValue(mockProfileStorage),
            userAccessibleContentsControllerProvider
                .overrideWith((ref) => mockAccessibleContents),
            teamListControllerProvider.overrideWith(
              (ref) => AsyncValue.data([team]),
            ),
          ],
          child: child,
        ),
      );

      // Premium だがボールが残っている場合は available になるべき
      expect(result.current, FabState.available);
    });

    test('should return unavailable when canSubscribe is false', () async {
      final team = Team(
        id: testTeamId,
        teamType: TeamType.single,
        teamPlan: TeamPlan(
          plan: const Plan(
            name: 'standard',
            maxBalls: 100,
          ),
          currentUsage: 100, // reached limit
        ),
      );

      final result = await buildHook(
        () => useFabState(
          session: testSession,
          teamId: testTeamId,
          canSubscribe: false, // cannot subscribe
        ),
        wrapper: (child) => ProviderScope(
          overrides: [
            profileStorageProvider.overrideWithValue(mockProfileStorage),
            userAccessibleContentsControllerProvider
                .overrideWith((ref) => mockAccessibleContents),
            teamListControllerProvider.overrideWith(
              (ref) => AsyncValue.data([team]),
            ),
          ],
          child: child,
        ),
      );

      expect(result.current, FabState.unavailable);
    });

    test('should return unavailable when team not found', () async {
      final result = await buildHook(
        () => useFabState(
          session: testSession,
          teamId: testTeamId,
          canSubscribe: true,
        ),
        wrapper: (child) => ProviderScope(
          overrides: [
            profileStorageProvider.overrideWithValue(mockProfileStorage),
            userAccessibleContentsControllerProvider
                .overrideWith((ref) => mockAccessibleContents),
            teamListControllerProvider.overrideWith(
              (ref) => AsyncValue.data([]), // no teams
            ),
          ],
          child: child,
        ),
      );

      expect(result.current, FabState.unavailable);
    });
  });
}
