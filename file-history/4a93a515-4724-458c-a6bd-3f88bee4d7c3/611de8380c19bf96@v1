                      context.l10n.session_details_page__spin_direction,
                      UnitConverter.formatSpinDirection(ball.spinDirection),
                      ColorManager.spinDirection,
                      orientation,
                    ),
                  ),
                  const Gap(6),
                  Expanded(
                    child: _buildMetricBadgeForLandscape(
                      context.l10n.session_details_page__active_spin,
                      UnitConverter.formatSpin(ball.activeSpin),
                      ColorManager.activeSpin,
                      orientation,
