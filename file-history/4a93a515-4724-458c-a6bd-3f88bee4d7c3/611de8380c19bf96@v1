            fontWeight: FontWeight.w500,
          ),
          maxLines: 1,
          overflow: TextOverflow.visible,
        ),
      ],
    ),
  );
}

class _RotatingStatusMessage extends StatelessWidget {
  const _RotatingStatusMessage({
    required this.statusMessage,
    required this.orientation,
  });

  final String statusMessage;
  final ValueNotifier<NativeDeviceOrientation> orientation;

  @override
  Widget build(BuildContext context) {
    return RotationContainer(
      orientation: orientation,
      child: Center(
        child: Text(
          statusMessage,
          style: TextStyle(
            color: ColorManager.cameraSettingValue,
            fontSize: 14,
            fontWeight: FontWeight.w500,
          ),
          textAlign: TextAlign.center,
        ),
      ),
    );
  }
}
