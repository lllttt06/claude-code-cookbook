class LatestAnalysisResultCard extends HookConsumerWidget {
  const LatestAnalysisResultCard({
    required this.sessionId,
    required this.teamId,
    required this.orientation,
    super.key,
  });

  final String sessionId;
  final String teamId;
  final ValueNotifier<NativeDeviceOrientation> orientation;

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final latestResultState = ref.watch(
      latestAnalysisResultControllerProvider(
        teamId: teamId,
        sessionId: sessionId,
      ),
    );

    return ValueListenableBuilder<NativeDeviceOrientation>(
      valueListenable: orientation,
      builder: (context, currentOrientation, child) {
        return Container(
          margin: EdgeInsets.symmetric(horizontal: 12, vertical: 6),
          decoration: BoxDecoration(
            color: Colors.black.withValues(alpha: 0.65),
            borderRadius: BorderRadius.circular(12),
          ),
          child: Padding(
            padding: const EdgeInsets.symmetric(vertical: 8, horizontal: 12),
            child: switch (latestResultState.pollingState) {
              PollingState.waitingForRecording ||
              PollingState.uploading ||
              PollingState.analyzing ||
              PollingState.failed =>
                Column(
                  children: [
                    // Show previous results while processing
                    if (latestResultState.previousResource != null) ...[
                      // Previous results section with visual indicator
                      _AnalysisResults(
                        orientation: orientation,
                        resource: latestResultState.previousResource,
                      ),
                      const Gap(8),
                      Divider(
                        color: Colors.white.withValues(alpha: 0.2),
                        height: 1,
                      ),
                      const Gap(8),
                    ],
                    // Current processing status with enhanced visual
                    RotationContainer(
                      orientation: orientation,
                      child: Column(
                        mainAxisAlignment: MainAxisAlignment.center,
                        children: [
                          // Processing indicator
                          if (latestResultState.pollingState ==
                                  PollingState.uploading ||
                              latestResultState.pollingState ==
                                  PollingState.analyzing)
                            VrtSafeProgressIndicator(
                              size: 18,
                              strokeWidth: 3,
                              color: ColorManager.cameraSettingValue,
                            )
                          else
                            Row(
                              mainAxisAlignment: MainAxisAlignment.center,
                              children: [
                                Text(
                                  switch (latestResultState.pollingState) {
                                    PollingState.waitingForRecording => context
                                        .l10n
                                        .session_details_page__no_ball_data,
                                    PollingState.failed => context.l10n
                                        .resource_details_page__analysis_failed,
                                    _ => '',
                                  },
                                  style: TextStyle(
                                    color: ColorManager.cameraSettingValue,
                                    fontSize: 14,
                                    fontWeight: FontWeight.w600,
                                  ),
                                ),
                              ],
                            ),
                        ],
                      ),
                    ),
                  ],
                ),
              PollingState.succeeded => _AnalysisResults(
                  orientation: orientation,
                  resource: latestResultState.currentResource,
                ),
            },
          ),
        );
      },
    );
  }
}

class _AnalysisResults extends HookConsumerWidget {
  const _AnalysisResults({
    required this.resource,
    required this.orientation,
  });

  final ResourceData? resource;
  final ValueNotifier<NativeDeviceOrientation> orientation;

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final unitType = ref.watch(appUnitProvider);
    final getAnalysisNotSucceededWord = useAnalysisNotSucceededOrEmptyWord();

    if (resource == null ||
        resource!.statusType != ResourceStatusType.analysisSucceeded ||
        resource!.ballInfoList == null ||
        resource!.ballInfoList!.isEmpty) {
      return _RotatingStatusMessage(
        statusMessage: getAnalysisNotSucceededWord(resource?.statusType),
        orientation: orientation,
      );
    }

    final ballInfo = resource!.ballInfoList!.first;
    final ball = ballInfo.ball;

    // Prioritize displaying pitching analysis results
    if (ball.isPitched == true) {
      return _buildPitchingMetrics(context, ball, unitType, orientation);
    }

    // Display hitting analysis results
    if (ball.isHit == true) {
      return _buildHittingMetrics(context, ball, unitType, orientation);
    }

    return const SizedBox.shrink();
  }

