                      context.l10n.session_details_page__total_spin,
                      UnitConverter.formatSpin(ball.totalSpin),
                      ColorManager.totalSpin,
                      orientation,
                    ),
                  ),
                  const Gap(6),
                  Expanded(
                    child: _buildMetricBadgeForLandscape(
                      context.l10n.session_details_page__gyro_degree,
                      UnitConverter.formatGyroDegree(ball.gyroDegree),
                      ColorManager.gyroDegree,
                      orientation,
                    ),
                  ),
                  const Gap(6),
                  Expanded(
                    child: _buildMetricBadgeForLandscape(
                      context.l10n.session_details_page__horizontal_break,
                      UnitConverter.formatBreak(ball.horizontalBreak, unitType),
                      ColorManager.horizontalBreak,
                      orientation,
                    ),
                  ),
                  const Gap(6),
                  Expanded(
                    child: _buildMetricBadgeForLandscape(
                      context.l10n.session_details_page__efficiency,
                      UnitConverter.formatEfficiency(ball.efficiency),
                      ColorManager.efficiency,
                      orientation,
