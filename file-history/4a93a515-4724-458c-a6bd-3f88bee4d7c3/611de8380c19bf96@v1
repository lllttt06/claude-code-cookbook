  Widget _buildHittingMetrics(
    BuildContext context,
    Ball ball,
    UnitType unitType,
    ValueNotifier<NativeDeviceOrientation> orientation,
  ) {
    return ValueListenableBuilder<NativeDeviceOrientation>(
      valueListenable: orientation,
      builder: (context, currentOrientation, child) {
        if (currentOrientation == NativeDeviceOrientation.landscapeLeft) {
          return Row(
            children: [
              Expanded(child: Container()),
              const Gap(6),
              Expanded(
                child: _buildMetricBadgeForLandscape(
                  context.l10n.session_details_page__angle,
                  UnitConverter.formatAngle(ball.angle),
                  ColorManager.angle,
                  orientation,
                ),
              ),
              const Gap(6),
              // Use 2 out of 4 divisions to match the same width as pitching
              Expanded(
                child: _buildMetricBadgeForLandscape(
                  context.l10n.session_details_page__exit_velocity,
                  UnitConverter.formatVelocity(ball.exitVelocity, unitType),
                  ColorManager.exitVelocity,
                  orientation,
                ),
              ),
              const Gap(6),
              Expanded(child: Container()),
            ],
          );
        } else if (currentOrientation ==
            NativeDeviceOrientation.landscapeRight) {
          return Row(
            children: [
              Expanded(child: Container()),
              const Gap(6),
              // Use 2 out of 4 divisions to match the same width as pitching
              Expanded(
                child: _buildMetricBadgeForLandscape(
                  context.l10n.session_details_page__exit_velocity,
                  UnitConverter.formatVelocity(ball.exitVelocity, unitType),
                  ColorManager.exitVelocity,
                  orientation,
                ),
              ),
              const Gap(6),
              Expanded(
                child: _buildMetricBadgeForLandscape(
                  context.l10n.session_details_page__angle,
                  UnitConverter.formatAngle(ball.angle),
                  ColorManager.angle,
                  orientation,
                ),
              ),
              const Gap(6),
              Expanded(child: Container()),
            ],
          );
        } else {
          // In portrait mode, keep the original horizontal layout
          return Row(
            children: [
              Expanded(child: Container()),
              const Gap(6),
              // Use 2 out of 4 divisions to match the same width as pitching
              Expanded(
                child: _buildMetricBadge(
                  context.l10n.session_details_page__exit_velocity,
                  UnitConverter.formatVelocity(ball.exitVelocity, unitType),
                  ColorManager.exitVelocity,
                  orientation,
                ),
              ),
              const Gap(6),
              Expanded(
                child: _buildMetricBadge(
                  context.l10n.session_details_page__angle,
                  UnitConverter.formatAngle(ball.angle),
                  ColorManager.angle,
                  orientation,
                ),
              ),
              const Gap(6),
              Expanded(child: Container()),
            ],
          );
        }
      },
    );
  }

  Widget _buildMetricBadge(
    String name,
    ValueAndUnit valueAndUnit,
    Color nameColor,
    ValueNotifier<NativeDeviceOrientation> orientation,
  ) {
    return RotationContainer(
      orientation: orientation,
      child: Column(
        children: [
          Container(
            padding: EdgeInsets.symmetric(horizontal: 6, vertical: 2),
            decoration: BoxDecoration(
              color: ColorManager.hover,
              borderRadius: BorderRadius.circular(6),
            ),
            child: Row(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                Text(
                  name,
                  textAlign: TextAlign.center,
                  style: TextStyle(
                    color: nameColor,
                    fontSize: 12,
                    fontWeight: FontWeight.w600,
                    letterSpacing: 0.2,
                  ),
                  maxLines: 1,
                  overflow: TextOverflow.ellipsis,
                ),
                if (valueAndUnit.unit.isNotEmpty)
                  Text(
                    " [${valueAndUnit.unit}]",
                    textAlign: TextAlign.center,
                    style: TextStyle(
                      color: nameColor,
                      fontSize: 10,
                      fontWeight: FontWeight.w500,
                    ),
                    maxLines: 1,
                    overflow: TextOverflow.visible,
                  ),
              ],
            ),
          ),
          Gap(4),
          Text(
            valueAndUnit.value,
            textAlign: TextAlign.center,
            style: TextStyle(
              color: Colors.white,
              fontSize: 14,
              fontWeight: FontWeight.w700,
            ),
            maxLines: 1,
            overflow: TextOverflow.visible,
          ),
        ],
      ),
    );
  }
