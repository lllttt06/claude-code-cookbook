                      UnitConverter.formatBreak(ball.verticalBreak, unitType),
                      ColorManager.verticalBreak,
                      orientation,
                    ),
                  ),
                  const Gap(6),
                  Expanded(
                    child: _buildMetricBadgeForLandscape(
                      context.l10n.session_details_page__initial_velocity,
                      UnitConverter.formatVelocity(
                          ball.initialVelocity, unitType),
                      ColorManager.initialVelocity,
                      orientation,
                    ),
