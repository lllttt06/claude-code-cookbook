// Package imports:
import 'package:baseball_detector_flutter/controllers/user_info_controller.dart';
import 'package:baseball_detector_flutter/providers/profile_storage_provider.dart';
import 'package:flutter/widgets.dart';
import 'package:riverpod_annotation/riverpod_annotation.dart';

// Project imports:
import 'package:baseball_detector_flutter/data/models/team.dart';
import 'package:baseball_detector_flutter/data/result.dart';

part 'super_admin_current_team_controller.g.dart';

@Riverpod(keepAlive: true)
class SuperAdminCurrentTeamController
    extends _$SuperAdminCurrentTeamController {
  @override
  Future<Team?> build() async {
    final initialTeam = ref.read(userInfoControllerProvider).fold(
          loading: () => null,
          error: (_) => null,
          data: (userInfo) {
            final teamId =
                ref.watch(profileStorageProvider.select((p) => p.getTeamId()));
            var team = userInfo.getTeam(teamId!);
            return team;
          },
        );
    return initialTeam;
  }

  void updateTeam(Team? team) {
    debugPrint('updateSuperAdmin: $team');
    state = AsyncData(team);
  }
}
