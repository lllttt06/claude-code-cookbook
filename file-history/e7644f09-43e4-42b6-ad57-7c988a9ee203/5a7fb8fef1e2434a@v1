// Package imports:
import 'package:flutter_test/flutter_test.dart';

// Project imports:
import 'package:baseball_detector_flutter/data/models/dto/resource/video_analyze_request.dart';
import 'package:baseball_detector_flutter/data/models/enums/unit_type.dart';

void main() {
  group('Testing VideoAnalyzeRequest', () {
    const resourceId = '00000000-0000-4000-8000-000000000000';
    final recordedAt = DateTime(2024, 1, 1);
    const focalLength = 24.0;
    const longsideAngleOfView = 25.0;
    const accX = 0.1;
    const accY = 9.8;
    const accZ = 0.1;
    const lens = 'lens';
    const focus = 0.2;
    const isAutoFocus = true;
    const analyzeType =
        1; // 1: pitching, 2: batting, 3: both, 4: pitching (all)
    const unit = UnitType.kmhCm;
    const zoom = 1.0;
    const iso = 3000.0;
    const shutterSpeed = 1.0;

    test('toJson1', () {
      final req = VideoAnalyzeRequest(
        resourceId: resourceId,
        recordedAt: recordedAt,
        longsideAngleOfView: longsideAngleOfView,
        focalLength: focalLength,
        accX: accX,
        accY: accY,
        accZ: accZ,
        lens: lens,
        focus: focus,
        isAutoFocus: isAutoFocus,
        analyzeType: analyzeType,
        unit: unit,
        zoom: zoom,
        iso: iso,
        shutterSpeed: shutterSpeed,
      );

      final reqJson = req.toJson();

      expect(reqJson.length, 15);

      expect(reqJson.containsKey('resourceId'), isTrue);
      expect(reqJson.containsKey('recordedAt'), isTrue);
      expect(reqJson.containsKey('longsideAngleOfView'), isTrue);
      expect(reqJson.containsKey('focalLength'), isTrue);
      expect(reqJson.containsKey('accX'), isTrue);
      expect(reqJson.containsKey('accY'), isTrue);
      expect(reqJson.containsKey('accZ'), isTrue);
      expect(reqJson.containsKey('lens'), isTrue);
      expect(reqJson.containsKey('focus'), isTrue);
      expect(reqJson.containsKey('isAutoFocus'), isTrue);
      expect(reqJson.containsKey('analyzeType'), isTrue);
      expect(reqJson.containsKey('unit'), isTrue);
      expect(reqJson.containsKey('zoom'), isTrue);
      expect(reqJson.containsKey('iso'), isTrue);
      expect(reqJson.containsKey('shutterSpeed'), isTrue);

      expect(reqJson['resourceId'], resourceId);
      expect(reqJson['recordedAt'], recordedAt.toIso8601String());
      expect(reqJson['longsideAngleOfView'], longsideAngleOfView);
      expect(reqJson['focalLength'], focalLength);
      expect(reqJson['accX'], accX);
      expect(reqJson['accY'], accY);
      expect(reqJson['accZ'], accZ);
      expect(reqJson['lens'], lens);
      expect(reqJson['focus'], focus);
      expect(reqJson['isAutoFocus'], isAutoFocus);
      expect(reqJson['analyzeType'], analyzeType);
      expect(reqJson['unit'], unit.toJson());
      expect(reqJson['zoom'], zoom);
      expect(reqJson['iso'], iso);
      expect(reqJson['shutterSpeed'], shutterSpeed);
    });
  });
}
