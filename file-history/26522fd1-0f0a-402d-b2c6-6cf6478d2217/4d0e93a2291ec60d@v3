// Package imports:
import 'package:freezed_annotation/freezed_annotation.dart';

part 'current_entitlement.freezed.dart';
part 'current_entitlement.g.dart';

/// iOS StoreKit 2 の currentEntitlements から返される
/// トランザクション情報を表すデータクラス
@freezed
abstract class CurrentEntitlement with _$CurrentEntitlement {
  @JsonSerializable(fieldRename: FieldRename.none)
  const factory CurrentEntitlement({
    /// トランザクション ID
    String? id,

    /// WebOrderLineItemID
    String? webOrderLineItemID,

    /// 購入日時 (ISO 8601 形式)
    String? purchaseDate,

    /// オリジナルトランザクション ID (サブスクリプション鎖の起点)
    String? originalId,

    /// オリジナル購入日時 (ISO 8601 形式)
    String? originalPurchaseDate,

    /// 製品 ID
    String? productId,

    /// 有効期限 (ISO 8601 形式、サブスクリプションの場合)
    String? expirationDate,

    /// 取り消し日時 (ISO 8601 形式、取り消された場合)
    String? revocationDate,
    List<String?>? status,

    /// 取り消し理由
    /// 0: Developer canceled
    /// 1: Customer canceled
    int? revocationReason,

    /// アップグレードされたかどうか
    bool? isUpgraded,

    /// StoreKit 2 の appAccountToken（UUID 文字列）
    /// Product.purchase(options: .appAccountToken(...)) で設定された場合に入る
    String? appAccountToken,
  }) = _CurrentEntitlement;

  factory CurrentEntitlement.fromJson(Map<String, dynamic> json) =>
      _$CurrentEntitlementFromJson(json);
}
