class _CoachMarkMediaSection extends StatefulWidget {
  const _CoachMarkMediaSection({
    required this.step,
    required this.styles,
  });

  final CoachMarkStep step;
  final _RecordingCoachMarkStyles styles;

  @override
  State<_CoachMarkMediaSection> createState() => _CoachMarkMediaSectionState();
}

class _CoachMarkMediaSectionState extends State<_CoachMarkMediaSection> {
  final PageController _pageController = PageController();
  int _currentPage = 0;

  @override
  void dispose() {
    _pageController.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    final children = <Widget>[];

    if (widget.step.hasImage) {
      final images = widget.step.imageList;
      if (images.length == 1) {
        children.add(
          ClipRRect(
            borderRadius: _RecordingCoachMarkStyles.mediaBorderRadius,
            child: images.first.image(
              width: double.infinity,
              fit: BoxFit.contain,
            ),
          ),
        );
      } else {
        children.add(
          Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              ClipRRect(
                borderRadius: _RecordingCoachMarkStyles.mediaBorderRadius,
                child: SizedBox(
                  width: double.infinity,
                  child: AspectRatio(
                    aspectRatio: 1,
                    child: PageView.builder(
                      controller: _pageController,
                      itemCount: images.length,
                      onPageChanged: (index) {
                        setState(() {
                          _currentPage = index;
                        });
                      },
                      itemBuilder: (context, index) {
                        return images[index].image(
                          width: double.infinity,
                          fit: BoxFit.contain,
                        );
                      },
                    ),
                  ),
                ),
              ),
              const Gap(12),
              Row(
                mainAxisAlignment: MainAxisAlignment.center,
                children: List.generate(
                  images.length,
                  (index) => Container(
                    width: 8,
                    height: 8,
                    margin: const EdgeInsets.symmetric(horizontal: 4),
                    decoration: BoxDecoration(
                      shape: BoxShape.circle,
                      color: _currentPage == index
                          ? _RecordingCoachMarkStyles.primaryColor
                          : _RecordingCoachMarkStyles.primaryColor
                              .withValues(alpha: 0.3),
                    ),
                  ),
                ),
              ),
            ],
          ),
        );
      }
    }

    if (widget.step.hasDescription) {
      if (children.isNotEmpty) {
        children.add(const Gap(16));
      }

      children.add(
        Text(
          widget.step.description!,
          style: widget.styles.descriptionTextStyle,
        ),
      );
    }

    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      mainAxisSize: MainAxisSize.min,
      children: children,
    );
  }
}

class _CoachMarkChecklist extends StatelessWidget {
