/// {@category Widgets}
library;

// Flutter imports:
import 'package:flutter/material.dart';

// Package imports:
import 'package:hooks_riverpod/hooks_riverpod.dart';

// Project imports:
import 'package:baseball_detector_flutter/l10n/l10n_ext.dart';
import 'package:baseball_detector_flutter/views/components/custom_text_form_field.dart';

class BirthdayFormField extends ConsumerWidget {
  final ValueNotifier<DateTime?> birthday;
  final bool enabled;
  final String? errorText;

  const BirthdayFormField({
    super.key,
    required this.birthday,
    this.enabled = true,
    this.errorText,
  });

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    return CustomTextFormField(
      controller: TextEditingController(
        text: birthday.value != null
            ? '${birthday.value!.year}/${birthday.value!.month.toString().padLeft(2, '0')}/${birthday.value!.day.toString().padLeft(2, '0')}'
            : '',
      ),
      label: Text(
        context.l10n.edit_player_page__birthday_label,
      ),
      hintText: context.l10n.edit_player_page__birthday_placeholder,
      readOnly: true,
      enabled: enabled,
      errorText: errorText,
      onTap: enabled
          ? () async {
              final picked = await showDatePicker(
                context: context,
                initialDate: birthday.value ??
                    DateTime.now().subtract(const Duration(days: 365 * 20)),
                firstDate: DateTime(1900),
                lastDate: DateTime.now(),
                helpText: context.l10n.edit_player_page__birthday_label,
                fieldLabelText: context.l10n.edit_player_page__birthday_label,
                builder: (BuildContext context, Widget? child) {
                  return Theme(
                    data: Theme.of(context),
                    child: child!,
                  );
                },
              );
              if (picked != null) {
                birthday.value = picked;
              }
            }
          : null,
    );
  }
}
