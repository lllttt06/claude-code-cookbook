// Flutter imports:
import 'package:baseball_detector_flutter/views/pages/home/sessions/session_details/components/ai_coach_promotion_container.dart';
import 'package:flutter/material.dart';

// Package imports:
import 'package:collection/collection.dart';
import 'package:gap/gap.dart';
import 'package:hooks_riverpod/hooks_riverpod.dart';

// Project imports:
import 'package:baseball_detector_flutter/controllers/resource_data_list_controller.dart';
import 'package:baseball_detector_flutter/data/models/paging_data.dart';
import 'package:baseball_detector_flutter/data/models/resource.dart';
import 'package:baseball_detector_flutter/data/models/session.dart';
import 'package:baseball_detector_flutter/l10n/l10n_ext.dart';
import 'package:baseball_detector_flutter/utils/build_context_ext.dart';
import 'package:baseball_detector_flutter/views/components/empty_view.dart';
import 'package:baseball_detector_flutter/views/components/paging_helper.dart';
import 'package:baseball_detector_flutter/views/pages/home/sessions/session_details/components/resource_card.dart';

class ResourceListTab extends ConsumerWidget {
  const ResourceListTab({
    required this.resourcePagingData,
    required this.session,
    required this.onRefresh,
    super.key,
  });

  final PagingData<ResourceData> resourcePagingData;
  final Session session;
  final Future<void> Function() onRefresh;

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    if (resourcePagingData.items.isEmpty || session.teamId == null) {
      return SingleChildScrollView(
        child: Column(
          children: [
            // Pattern 1: Simple Border
            AICoachPromotionContainer.simpleBorder(),
            const Gap(8),
            // Pattern 2: Gradient
            AICoachPromotionContainer.gradient(),
            const Gap(8),
            // Pattern 3: Card
            AICoachPromotionContainer.card(),
            const Gap(8),
            // Pattern 4: Outlined
            AICoachPromotionContainer.outlined(),
            const Gap(8),
            // Pattern 5: Shadowed
            AICoachPromotionContainer.shadowed(),
            const Gap(8),
            // Pattern 6: Neon
            AICoachPromotionContainer.neon(),
            const Gap(8),
            // Pattern 7: Minimal
            AICoachPromotionContainer.minimal(),
            const Gap(8),
            // Pattern 8: Badge
            AICoachPromotionContainer.badge(),
            const Gap(8),
            // Pattern 9: Ribbon
            AICoachPromotionContainer.ribbon(),
            const Gap(8),
            // Pattern 10: Glossy
            AICoachPromotionContainer.glossy(),
            const Gap(16),
            EmptyView(
              message: context.l10n.session_details_page__no_data,
            ),
          ],
        ),
      );
    }

    final teamId = session.teamId!;

    return RefreshIndicator(
      onRefresh: onRefresh,
      child: SizedBox(
        height: context.screenHeight,
        child: SingleChildScrollView(
          physics: const AlwaysScrollableScrollPhysics(),
          child: Column(
            children: [
              AICoachPromotionContainer.simpleBorder(),
              const Gap(8),
              ...resourcePagingData.items.mapIndexed(
                (index, resource) => Container(
                  margin: const EdgeInsetsDirectional.only(
                    bottom: 8,
                  ),
                  child: ResourceCard(
                    teamId: teamId,
                    session: session,
                    resource: resource,
                    isLastItem: index == resourcePagingData.items.length - 1 &&
                        index != 0,
                  ),
                ),
              ),
              if (resourcePagingData.hasMore)
                EndItemView(
                  visibilityKey: Key(
                    'EndItem_${resourcePagingData.items.length}',
                  ),
                  onScrollEnd: () {
                    ref
                        .read(
                          resourceDataListControllerProvider(
                            teamId: teamId,
                            sessionId: session.id!,
                          ).notifier,
                        )
                        .loadNext();
                  },
                ),
            ],
          ),
        ),
      ),
    );
  }
}
