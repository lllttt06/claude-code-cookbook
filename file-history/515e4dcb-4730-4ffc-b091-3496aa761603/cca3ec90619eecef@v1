// Package imports:
import 'package:flutter_test/flutter_test.dart';

// Project imports:
import 'package:baseball_detector_flutter/data/models/dto/resource/resource_search_request.dart';

void main() {
  group('Testing ResourceSearchRequest', () {
    const keyword = 'keyword';
    const userId = 'aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa';
    const isBallPitched = true;
    final dateFrom = DateTime(2024, 1, 1);
    final dateTo = DateTime(2024, 1, 1, 23, 59, 59, 999, 999);
    const page = 0;
    const pageSize = 20;
    const orderBy = ResourceSearchRequestOrderBy.id;
    const isOrderDesc = false;

    test('toJson1', () {
      final req = ResourceSearchRequest(
        keyword: keyword,
        userId: userId,
        isBallPitched: isBallPitched,
        dateFrom: dateFrom,
        dateTo: dateTo,
        page: page,
        pageSize: pageSize,
        orderBy: orderBy,
        isOrderDesc: isOrderDesc,
      );

      final reqJson = req.toJson();

      expect(reqJson.length, 9);

      expect(reqJson.containsKey('keyword'), isTrue);
      expect(reqJson.containsKey('userId'), isTrue);
      expect(reqJson.containsKey('isBallPitched'), isTrue);
      expect(reqJson.containsKey('dateFrom'), isTrue);
      expect(reqJson.containsKey('dateTo'), isTrue);
      expect(reqJson.containsKey('page'), isTrue);
      expect(reqJson.containsKey('pageSize'), isTrue);
      expect(reqJson.containsKey('orderBy'), isTrue);
      expect(reqJson.containsKey('isOrderDesc'), isTrue);

      expect(reqJson['keyword'], keyword);
      expect(reqJson['userId'], userId);
      expect(reqJson['isBallPitched'], isBallPitched);
      expect(reqJson['dateFrom'], dateFrom.toIso8601String());
      expect(reqJson['dateTo'], dateTo.toIso8601String());
      expect(reqJson['page'], page);
      expect(reqJson['pageSize'], pageSize);
      expect(reqJson['orderBy'], orderBy.name);
      expect(reqJson['isOrderDesc'], isOrderDesc);
    });
  });
}
