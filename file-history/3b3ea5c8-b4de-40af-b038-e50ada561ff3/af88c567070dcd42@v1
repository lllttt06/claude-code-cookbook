#!/bin/bash

executePsql() {
	DB_HOST=${1}_DB_HOST
	DB_PORT=${1}_DB_PORT
	DB_USER=${1}_DB_USER
	DB_PASSWORD=${1}_DB_PASSWORD
	PGPASSWORD=${!DB_PASSWORD} psql --host="${!DB_HOST}" --port="${!DB_PORT}" --username="${!DB_USER}" "${@:2}"
}

executeSqlStmt() {
	local env=$1
	local sql=$2
	executePsql "$env" --file=<(echo "$sql")
}

cd "$(dirname "$0")"

# Importing variables
# NOTE: Copy .env.example to create .env and edit it as needed.
source ../.env


executeSqlStmt API "$(cat <<EOF

UPDATE "public"."players" SET "delete_flag" = FALSE WHERE "delete_flag" IS TRUE;
UPDATE "public"."sessions" SET "delete_flag" = FALSE WHERE "delete_flag" IS TRUE;
UPDATE "public"."resources" SET "delete_flag" = FALSE WHERE "delete_flag" IS TRUE;

EOF
)"
