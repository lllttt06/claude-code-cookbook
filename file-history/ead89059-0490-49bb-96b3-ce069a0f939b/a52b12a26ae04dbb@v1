  /**
   * Clean up a user account if it has been deactivated.
   *
   * - Deletes the user if the account is deactivated or scheduled for
   *   deletion.
   * - Does not delete active or unconfirmed users.
   * - Throws an exception if the user is active or unconfirmed, depending on
   *   the provided options.
   * - Deactivates related teams if the user was deleted.
   *
   * @param email The email address of the user to check and possibly delete.
   * @param options Optional behavior flags:
   *   - `throwErrorIfUserIsActive` (default: false): Throws if the user is
   *     active.
   *   - `throwErrorIfUserIsUnconfirmed` (default: false): Throws if the user
   *     has not confirmed their account.
   * @throws CodedInvalidArgumentException if the user is active or
   *     unconfirmed and the corresponding flag is enabled.
   * @returns The user found and whether it was deleted.
   */
  @CodedMethod('CUID')
  private async cleanUserIfDeactivated(
    email: string,
    parameters: {
      joinProfileOnUser?: boolean;
      throwErrorIfUserIsActive: boolean;
      throwErrorIfUserIsUnconfirmed: boolean;
    },
  ): Promise<{ user: User | null; isDeleted: boolean }> {
    const cbuilder = this.getCodeBuilder();

    // Search the user with email regardless of its condition,
    // i.e., even if it was deleted or scheduled deletion.
    const { user, teamIds } = await this.datasource.manager.transaction(
      async (t) => {
        const user = await this.usersPersistence.findUserByEmail(t, email, {
          joinUserRole: true,
          joinProfile: parameters.joinProfileOnUser,
          includeDeletedUser: true,
          includeDeletionScheduledUser: true,
        });

        return {
          user,
          teamIds: user?.userRoles.map((x) => x.teamId) ?? [],
        };
      },
    );

    if (!user) {
      this.logger.debug(
        `[Cleaning] The user with email=${email} not found. Skipped.`,
      );
      // The user having the email is not found, then do nothing.
      return { user: null, isDeleted: false };
    }

    const userId = user.id;

    const isUnconfirmed = !user.hashedPassword;
    const isPendingDeletion = !!user.deletedAt || !!user.deletionScheduledAt;
    const isActive = !isPendingDeletion && !isUnconfirmed;
    const shouldThrowError =
      (parameters.throwErrorIfUserIsActive && isActive) ||
      (parameters.throwErrorIfUserIsUnconfirmed && isUnconfirmed) ||
      isPendingDeletion; // TODO: 削除処理の完成までの一時的な措置：https://knowhere-org.slack.com/archives/C07D9BA4A9W/p1760166939088579

    if (shouldThrowError) {
      throw new CodedInvalidArgumentException(
        this.code,
        this.EC.USER_ALREADY_IN_USE(cbuilder.build()),
      );
    }

    if (!isPendingDeletion) {
      // Do not delete a user who is not for pending deletion
      return { user, isDeleted: false };
    }

    this.logger.debug(`Cleaning user: u=${userId}`);

    await this.deleteUsers([user.id]);
    await this.datasource.transaction(async (t) => {
      await this.teamsPersistence.deactivateTeamsIfNeeded(t, teamIds);
    });

    return { user, isDeleted: true };
  }

  @CodedMethod('CIUD')
  private async createInitialUserData(
    t: EntityManager,
    userId: string,
    data: {
      name: string;
      email: string;
      birthday?: string | null;
      profileImageUrl?: string | null;
      hashedPassword?: string;
      verificationCode?: string;
      verificationCodeExpiration?: Date;
      emailVerificationToken?: string;
      emailVerificationTokenExpiration?: Date;
      emailVerified?: boolean;
    },
    requestContext: { lang: string | null } = { lang: null },
  ) {
    const cbuilder = this.getCodeBuilder();
    const now = new Date();

    await t.save(User, {
      id: userId,
      email: data.email,
      hashedPassword: data.hashedPassword,
      verificationCode: data.verificationCode,
      verificationCodeExpiration: data.verificationCodeExpiration,
      emailVerificationToken: data.emailVerificationToken,
      emailVerificationTokenExpiration: data.emailVerificationTokenExpiration,
      emailVerified: data.emailVerified,
      createdAt: now,
      updatedAt: now,
    });

    await t.save(Profile, {
      id: userId,
      userId: userId,
      username: data.name,
      birthday: data.birthday,
      imageUrl: data.profileImageUrl,
    });
  }

  private async createInitialUserRole(
    t: EntityManager,
    userId: string,
    teamId: string,
    name: RoleGroupName,
  ) {
    const roleGroup = await t.findOne(RoleGroup, {
      where: {
        name,
      },
    });

    await t.insert(UserRole, {
      userId,
      teamId,
      roleGroupId: roleGroup!.id,
    });
  }

  private async prepareTokenAndSendSignUpLinkEmail(
    userId: string,
    email: string,
    lang: string,
    logInfo: {
      teamId: string;
      requesterUid: string;
    },
  ) {
    const randomHexData = StringUtil.getRandomHex();

    const tokenExpirationDate = moment(new Date())
      .add(this.configProvider.config.defaultTokenExpirationSeconds, 'seconds')
      .toDate();

    await this.datasource.manager.transaction(async (t) => {
      await t.update(
        User,
        {
          id: userId,
        },
        {
          emailVerificationToken: randomHexData.hex,
          emailVerificationTokenExpiration: tokenExpirationDate,
        },
      );
    });

    await this.emailProvider.sendSignUpLinkEmail({
      userId: userId,
      email: email,
      token: randomHexData.hex,
      lang,
    });

    const exprStr = moment(tokenExpirationDate).format(
      AppConstants.default_datetime_format,
    );
    this.logger.log(
      `User: [${email}](id=${userId}) is invited to team_id=[${logInfo.teamId}]` +
        `, expiration: ${exprStr}, invited by: ${logInfo.requesterUid}`,
    );
  }

  @CodedMethod('CEVS')
  async checkEmailVerificationStatus(email: string) {
    const cbuilder = this.getCodeBuilder();
    return await this.datasource.manager.transaction(async (t) => {
      const user = await this.usersPersistence.findUserByEmail(t, email);
      if (!user) {
        return {
          status: 'not_created', // Change to 'unknown' if you want to hide existence of the account
        };
      } else if (user.emailVerified) {
        return {
          status: 'verified', // Change to 'unknown' if you want to hide existence of the account
        };
      }

      return {
        status: 'not_verified',
      };
    });
  }

  @CodedMethod('CPU')
  async createPersonalUser(
    email: string,
    name?: string,
    birthday?: string | null,
    requestContext: {
      lang: string | null;
    } = {
      lang: null,
    },
    mode: 'code' | 'link' = 'code',
  ): Promise<{
    userId: string;
  }> {
    const cbuilder = this.getCodeBuilder();
    if (birthday && !this.canRegisterUser(birthday)) {
      throw new CodedInvalidArgumentException(
        this.code,
        this.EC.USER_MUST_BE_AT_LEAST_13_YEARS_OLD(cbuilder.build()),
      );
    }
    const now = new Date();

    const targetUser = await this.cleanUserIfDeactivated(email, {
      joinProfileOnUser: true,
      throwErrorIfUserIsActive: true,
      throwErrorIfUserIsUnconfirmed: false,
    });

    const randomHexData = StringUtil.getRandomHex();
    const code = Math.floor(
      StringUtil.getRandomHex().number % 1000000,
    ).toString();

    const userId = await this.datasource.manager.transaction(async (t) => {
      // Check user existence
      const existingUser = await this.usersPersistence.findUserByEmail(
        t,
        email,
      );

      // Check team existence
      const existingTeam = existingUser
        ? await t.findOne(Team, {
            where: {
              teamType: TeamType.SINGLE,
              deletedAt: IsNull(),
              deletionScheduledAt: IsNull(),
              userRoles: {
                userId: existingUser.id,
              },
            },
          })
        : null;

      const userId = existingUser?.id ?? uuidv4();
      let teamId = existingTeam?.id;
      if (!existingTeam) {
        // Create a team first.

        const teamName = this.i18n.translate('_.initial.team_name', {
          lang: requestContext.lang ?? 'en',
        });
        const { team } = await this.teamsPersistence.createTeamWithItem(t, {
          name: teamName,
          ownerUserId: userId,
          teamType: TeamType.SINGLE,
          itemName: 'Free Sample',
        });
        teamId = team.id;
      }

      // Create a user.

      const tokenExpirationDate = moment(new Date())
        .add(
          this.configProvider.config.defaultTokenExpirationSeconds,
          'seconds',
        )
        .toDate();

      birthday =
        birthday ??
        (targetUser.user?.profile.birthday
          ? moment(targetUser.user?.profile.birthday).format('YYYY-MM-DD')
          : null);

      await this.createInitialUserData(
        t,
        userId,
        {
          email,
          name: name ?? targetUser.user?.profile.username ?? email,
          profileImageUrl: null,
          birthday,
          verificationCode: code,
          verificationCodeExpiration: moment(now).add(1, 'day').toDate(),
          ...(mode === 'link'
            ? {
                emailVerificationToken: randomHexData.hex,
                emailVerificationTokenExpiration: tokenExpirationDate,
              }
            : {}),
        },
        { lang: requestContext.lang },
      );

      if (!existingTeam) {
        // かつてこのメソッド内でuserId, teamIdが同一のUserRoleを削除していた。
        // このteamIdは新しく作られているため、削除の必要はない。
        // 他の呼び出し箇所も同様のため、削除を削除。
        await this.createInitialUserRole(t, userId, teamId!, 'personal_user');

        await this.createInitialPlayerForSingleTeam(
          t,
          userId,
          teamId!,
          birthday,
          requestContext,
        );
      }

      return userId;
    });

    if (mode === 'link') {
      await this.emailProvider.sendSignUpLinkEmail({
        userId,
        email,
        token: randomHexData.hex,
        lang: requestContext.lang,
      });
      return {
        userId,
      };
    } else {
      await this.emailProvider.sendSignUpCodeEmail({
        email,
        code,
        lang: requestContext.lang,
      });
      return {
        userId,
      };
    }
  }

