import { HttpService } from '@nestjs/axios';
import { CacheModule } from '@nestjs/cache-manager';
import { INestApplication } from '@nestjs/common';
import { Test } from '@nestjs/testing';
import _ from 'lodash';
import request from 'supertest';
import { DataSource } from 'typeorm';
import { v4 as uuidv4 } from 'uuid';

import { StringUtil } from '@/app/common/utils/string.util';
import { Profile } from '@/app/models/profile';
import { User } from '@/app/models/user';
import { AppModule } from '@/app/modules/app.module';
import { SubscriptionsPersistence } from '@/app/persistence/subscriptions.persistence';
import { TeamItemsPersistence } from '@/app/persistence/team-items.persistence';
import { TeamSubscriptionsPersistence } from '@/app/persistence/team-subscriptions.persistence';
import { TeamsPersistence } from '@/app/persistence/teams.persistence';
import { UsersPersistence } from '@/app/persistence/users.persistence';
import { StorageProvider } from '@/app/providers/storage.provider';
import { users } from '@/database/seeding/generators/data/users';
import { DataUtil as TestDataUtil } from '@/database/seeding/generators/utils/data.util';

import {
  invitation1HtmlEn,
  invitation1HtmlJa,
} from '@test/data/email/invitations';
import {
  passwordReset1HtmlEn,
  passwordReset1HtmlJa,
} from '@test/data/email/password-reset';
import { signup1HtmlEn, signup1HtmlJa } from '@test/data/email/signup';
import { TestUtil } from '@test/utils/test.util';
import { UserTestUtil } from '@test/utils/user-test.util';

const userFinder = TestDataUtil.getFinder(users);

describe('User(Team)', () => {
  let app: INestApplication;
  let httpService: HttpService;
  let dataSource: DataSource;

  beforeAll(async () => {
    const moduleRef = await Test.createTestingModule({
      imports: [AppModule, CacheModule.register()],
      providers: [
        TeamsPersistence,
        TeamItemsPersistence,
        TeamSubscriptionsPersistence,
        UsersPersistence,
        StorageProvider,
        SubscriptionsPersistence,
      ],
    }).compile();

    app = moduleRef.createNestApplication();
    await app.init();

    dataSource = app.get(DataSource);

    httpService = moduleRef.get<HttpService>(HttpService);
  });

  const signup = async (data: {
    email: string;
    name: string;
    birthday: string;
    inviteMode: 'link' | 'code';
    lang: 'en' | 'ja';
  }) => {
    // TODO: 一時的に？削除予約されたユーザーのメールアドレスでのサインアップ不可。
    // create a user pending deletion
    // const pendingDeletionUserRecords =
    //   await UserTestUtil.createUserPendingForDeletion(app, data.email);

    // first signup request
    // (this also serves as a test for cleanUserIfDeactivated)
    const firstSignupResult = await request(app.getHttpServer())
      .post(`/api/auth/signup`)
      .set({
        'Accept-Language': data.lang,
        'X-Api-Version': `${TestUtil.getApiTestVersion()}`,
      })
      .send({
        email: data.email,
        name: data.name,
        birthday: data.birthday,
        inviteMode: data.inviteMode,
      })
      .expect(201);

    // await UserTestUtil.expectDeletionOfUserRelatedRecords(
    //   dataSource,
    //   pendingDeletionUserRecords,
    // );

    const firstUserId = firstSignupResult.body.userId as string;
    const firstUserRelatedRecords =
      await UserTestUtil.expectAndExtractUserRelatedRecords(
        dataSource,
        firstUserId,
      );

    // resend email by signup again
    // (test that this does not delete the user)
    const signupResult = await request(app.getHttpServer())
      .post(`/api/auth/signup`)
      .set({
        'Accept-Language': data.lang,
        'X-Api-Version': `${TestUtil.getApiTestVersion()}`,
      })
      .send({
        email: data.email,
        inviteMode: data.inviteMode,
      })
      .expect(201);

    await UserTestUtil.expectPreservationOfUserRelatedRecords(
      dataSource,
      firstUserRelatedRecords,
    );
    const userId = signupResult.body.userId as string;
    expect(firstUserId).toBe(userId);

    return userId;
  };

  const signupWithLink = async (lang: 'en' | 'ja') => {
    // The sign up flow with verification code
    // 1. Create a user by /api/auth/signup with email (and optional user name).
    // 2. API server sends to the user an email verification token via email.
    // 3. Initialize password by /api/auth/reset-password with the email verification token.

    const startingDate = new Date();
    const randomStr = StringUtil.getRandomHex().hex;
    const email = `testcase_invited_${randomStr}@example.com`;
    const name = 'test';
    const birthday = '2000-01-01';
    const password = 'test123';

    const userId = await signup({
      email,
      name,
      birthday,
      inviteMode: 'link',
      lang,
    });
    const userProfile = await dataSource.manager.findOne(Profile, {
      where: {
        id: userId,
      },
    });
    expect(userProfile?.username).toBe(name);
    expect(userProfile?.birthday).toBe(birthday);

    const userInDatabase = await dataSource.manager.findOne(User, {
      where: {
        id: userId,
      },
    });
    expect(userInDatabase?.emailVerificationToken).toBeTruthy();
    expect(userInDatabase?.emailVerificationTokenExpiration).toBeTruthy();

    // With wrong token
    await request(app.getHttpServer())
      .put(`/api/auth/password-reset`)
      .set({
        'Accept-Language': lang,
        'X-Api-Version': `${TestUtil.getApiTestVersion()}`,
      })
      .send({
        userId,
        password,
        token: 'wrong token',
      })
      .expect(400);

    // With correct token
    await request(app.getHttpServer())
      .put(`/api/auth/password-reset`)
      .set({
        'Accept-Language': lang,
        'X-Api-Version': `${TestUtil.getApiTestVersion()}`,
      })
      .send({
        userId,
        password,
        token: userInDatabase?.emailVerificationToken,
      })
      .expect(200);

    const userInDatabaseAfterPasswordReset = await dataSource.manager.findOne(
      User,
      {
        where: {
          id: userId,
        },
      },
    );
    expect(userInDatabaseAfterPasswordReset?.emailVerified).toBe(true);

    const latestEmail = await TestUtil.getLatestEmailFromInbucket(httpService, {
      email,
      dateAfter: startingDate,
    });
    expect(latestEmail).toBeTruthy();

    // Cannot signup after verification
    const signupResultAfterVerification = await request(app.getHttpServer())
      .post(`/api/auth/signup`)
      .set({
        'Accept-Language': lang,
        'X-Api-Version': `${TestUtil.getApiTestVersion()}`,
      })
      .send({
        email,
        name,
        birthday,
        inviteMode: 'link',
      })
      .expect(400);

    return {
      email: latestEmail!,
      user: userInDatabase!,
    };
  };

  it(`Signup with Link (EN)`, async () => {
    const { email, user } = await signupWithLink('en');

    expect(email).toMatchObject({
      from: '<noreply@knowhere.co.jp>',
      subject: '[LOCAL] [SmartScout] User Registration',
    });
    expect(_.trim(email.body.html, '\n')).toMatch(
      invitation1HtmlEn(user.id, `${user.emailVerificationToken!}`),
    );
  });

  it(`Signup with Link (JA)`, async () => {
    const { email, user } = await signupWithLink('ja');

    expect(email).toMatchObject({
      from: '<noreply@knowhere.co.jp>',
      subject: '[LOCAL] [SmartScout] ユーザー登録',
    });
    expect(_.trim(email.body.html, '\n')).toMatch(
      invitation1HtmlJa(user.id, `${user.emailVerificationToken!}`),
    );
  });

  const signupWithCode = async (lang: 'en' | 'ja') => {
    // The sign up flow with verification code
    // 1. Create a user by /api/auth/signup with email (and optional user name).
    // 2. API server sends to the user a verification code via email.
    // 3. Get a temporary token by /api/auth/code-verification with the verification code.
    // 4. Initialize password by /api/auth/reset-password/initial with the temporary token.

    const startingDate = new Date();
    const password = 'test123';
    const randomStr = StringUtil.getRandomHex().hex;
    const email = `testcase_invited_${randomStr}@example.com`;
    const name = 'test';
    const birthday = '2000-01-01';

    const userId = await signup({
      email,
      name,
      birthday,
      inviteMode: 'code',
      lang,
    });
    const userProfile = await dataSource.manager.findOne(Profile, {
      where: {
        id: userId,
      },
    });
    expect(userProfile?.username).toBe(name);
    expect(userProfile?.birthday).toBe(birthday);

    const userInDatabase = await dataSource.manager.findOne(User, {
      where: {
        id: userId,
      },
    });
    expect(userInDatabase?.verificationCode).toBeTruthy();

    // With wrong code
    await request(app.getHttpServer())
      .get(`/api/auth/code-verification`)
      .set({
        'Accept-Language': lang,
        'X-Api-Version': `${TestUtil.getApiTestVersion()}`,
      })
      .query({
        email,
        code: 'wrong code',
      })
      .expect(400);

    // With correct code
    const resultOfCorrectCodeVerification = await request(app.getHttpServer())
      .get(`/api/auth/code-verification`)
      .set({
        'Accept-Language': lang,
        'X-Api-Version': `${TestUtil.getApiTestVersion()}`,
      })
      .query({
        email,
        code: userInDatabase!.verificationCode!,
      })
      .expect(200);

    const userInDatabaseAfterCodeVerification =
      await dataSource.manager.findOne(User, {
        where: {
          id: userId,
        },
      });
    expect(userInDatabaseAfterCodeVerification?.temporallyToken).toBeTruthy();

    expect(resultOfCorrectCodeVerification.body.token).toMatch(
      userInDatabaseAfterCodeVerification!.temporallyToken!,
    );
    expect(userInDatabaseAfterCodeVerification?.emailVerified).toBe(true);

    await request(app.getHttpServer())
      .put(`/api/auth/password-reset/initial`)
      .set({
        'Accept-Language': lang,
        'X-Api-Version': `${TestUtil.getApiTestVersion()}`,
      })
      .send({
        userId,
        password,
        token: resultOfCorrectCodeVerification.body.token,
      })
      .expect(200);

    // Cannot signup after verification
    const signupResultAfterVerification = await request(app.getHttpServer())
      .post(`/api/auth/signup`)
      .set({
        'Accept-Language': lang,
        'X-Api-Version': `${TestUtil.getApiTestVersion()}`,
      })
      .send({
        email,
        name,
        inviteMode: 'code',
        birthday,
      })
      .expect(400);

    const latestEmail = await TestUtil.getLatestEmailFromInbucket(httpService, {
      email,
      dateAfter: startingDate,
    });
    expect(latestEmail).toBeTruthy();

    return {
      email: latestEmail!,
      user: userInDatabase!,
    };
  };

  it(`Signup with Code (EN)`, async () => {
    const { email, user } = await signupWithCode('en');

    expect(email).toMatchObject({
      from: '<noreply@knowhere.co.jp>',
      subject: '[LOCAL] [SmartScout] User Registration',
    });
    expect(_.trim(email.body.html, '\n')).toMatch(
      signup1HtmlEn(`${user.verificationCode!}`),
    );
  });

  it(`Signup with Code (JA)`, async () => {
    const { email, user } = await signupWithCode('ja');

    expect(email).toMatchObject({
      from: '<noreply@knowhere.co.jp>',
      subject: '[LOCAL] [SmartScout] ユーザー登録',
    });
    expect(_.trim(email.body.html, '\n')).toMatch(
      signup1HtmlJa(`${user.verificationCode!}`),
    );
  });

  const passwordResetProcedure = async (lang: 'en' | 'ja') => {
    const startingDate = new Date();
    const targetUser = userFinder.getByTag(`pass_reset1-team_b`);
    const email = targetUser.email!;

    const result = await request(app.getHttpServer())
      .post(`/api/auth/password-reset/email`)
      .set({
        'Accept-Language': lang,
        'X-Api-Version': `${TestUtil.getApiTestVersion()}`,
      })
      .send({
        email,
      })
      .expect(201);

    const userInDatabase = await dataSource.manager.findOne(User, {
      where: {
        id: targetUser.id,
      },
    });
    expect(userInDatabase).toBeTruthy();

    const latestEmail = await TestUtil.getLatestEmailFromInbucket(httpService, {
      email,
      dateAfter: startingDate,
    });
    expect(latestEmail).toBeTruthy();

    return {
      data: latestEmail!,
      user: userInDatabase!,
    };
  };

  it(`Password reset (EN)`, async () => {
    const emailData = await passwordResetProcedure('en');

    expect(emailData.data).toMatchObject({
      from: '<noreply@knowhere.co.jp>',
      subject: '[LOCAL] [SmartScout] Password Reset',
    });
    expect(_.trim(emailData.data.body.html, '\n')).toMatch(
      passwordReset1HtmlEn(`${emailData.user.emailVerificationToken!}`),
    );
  });

  it(`Password reset (JA)`, async () => {
    const emailData = await passwordResetProcedure('ja');

    expect(emailData.data).toMatchObject({
      from: '<noreply@knowhere.co.jp>',
      subject: '[LOCAL] [SmartScout] パスワードリセット',
    });
    expect(_.trim(emailData.data.body.html, '\n')).toMatch(
      passwordReset1HtmlJa(`${emailData.user.emailVerificationToken!}`),
    );
  });

  describe('GET /auth/users/verification-status', () => {
    it('should return not_created for non-existent user', async () => {
      const nonExistentEmail = `non_existent_${StringUtil.getRandomHex().hex}@example.com`;

      const response = await request(app.getHttpServer())
        .get('/api/auth/users/verification-status')
        .query({ email: nonExistentEmail })
        .set({
          'X-Api-Version': `${TestUtil.getApiTestVersion()}`,
        })
        .expect(200);

      expect(response.body).toEqual({
        status: 'not_created',
      });
    });

    it('should return verified for email-verified user', async () => {
      const randomStr = StringUtil.getRandomHex().hex;
      const email = `verified_user_${randomStr}@example.com`;
      const userId = uuidv4();

      // Create a verified user
      await dataSource.manager.save(User, {
        id: userId,
        email: email,
        hashedPassword: 'dummy_hash',
        emailVerified: true,
        createdAt: new Date(),
        updatedAt: new Date(),
      });

      const response = await request(app.getHttpServer())
        .get('/api/auth/users/verification-status')
        .query({ email })
        .set({
          'X-Api-Version': `${TestUtil.getApiTestVersion()}`,
        })
        .expect(200);

      expect(response.body).toEqual({
        status: 'verified',
      });

      // Cleanup
      await dataSource.manager.delete(User, { id: userId });
    });

    it('should return not_verified for user with password but not email-verified', async () => {
      const randomStr = StringUtil.getRandomHex().hex;
      const email = `unverified_with_password_${randomStr}@example.com`;
      const userId = uuidv4();

      // Create a user with hashedPassword but emailVerified = false
      // This simulates the edge case where user has password but hasn't verified email
      await dataSource.manager.save(User, {
        id: userId,
        email: email,
        hashedPassword: 'dummy_hash',
        emailVerified: false,
        createdAt: new Date(),
        updatedAt: new Date(),
      });

      const response = await request(app.getHttpServer())
        .get('/api/auth/users/verification-status')
        .query({ email })
        .set({
          'X-Api-Version': `${TestUtil.getApiTestVersion()}`,
        })
        .expect(200);

      expect(response.body).toEqual({
        status: 'not_verified',
      });

      // Cleanup
      await dataSource.manager.delete(User, { id: userId });
    });
  });

  afterAll(async () => {
    await dataSource.destroy();
    await app.close();
  });
});
