import 'package:baseball_detector_flutter/data/models/failure/failure.dart';

/// Represents 400 error
class BadRequestFailure extends BaseHttpResponseFailure {
  BadRequestFailure({
    required super.code,
    super.status,
    super.description,
    super.underlyingException,
    super.stackTrace,
    super.title,
    super.response,
  }) : super(
          type: 'badRequest',
          defaultStatus: 400,
          defaultDescription: (l10n) => l10n.failure__bad_request,
        );

  @override
  String toString() {
    // Use runtimeType to get the actual class name
    return '$runtimeType(${formatArgs()})';
  }

  /// メッセージキーから具体的な Failure クラスのインスタンスを生成
  static BadRequestFailure fromMessage(
    String message, {
    required String code,
    int? status,
    FailureDescription? description,
    Object? underlyingException,
    StackTrace? stackTrace,
    String? title,
    Object? response,
  }) {
    return switch (message) {
      'already_has_team_plan' => AlreadyHasTeamPlanFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'already_in_use' => AlreadyInUseFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'already_processed_apple_transaction' =>
        AlreadyProcessedAppleTransactionFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'apple_api_error' => AppleApiErrorFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'bound_sessions_existing' => BoundSessionsExistingFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'cannot_change_plan' => CannotChangePlanFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'failed_to_authorize' => FailedToAuthorizeFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'failed_to_create_user' => FailedToCreateUserFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'failed_to_invite_user' => FailedToInviteUserFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'file_size_exceeded' => FileSizeExceededFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'invalid_ball_id' => InvalidBallIdFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'invalid_ai_coach_report_id' => InvalidAiCoachReportIdFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'invalid_code' => InvalidCodeFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'invalid_email' => InvalidEmailFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'invalid_notification_id' => InvalidNotificationIdFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'invalid_pitch_type_id' => InvalidPitchTypeIdFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'invalid_plan_id' => InvalidPlanIdFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'invalid_player_id' => InvalidPlayerIdFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'invalid_resource_id' => InvalidResourceIdFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'invalid_session_id' => InvalidSessionIdFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'invalid_team_id' => InvalidTeamIdFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'invalid_team_plan' => InvalidTeamPlanFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'invalid_transaction_info' => InvalidTransactionInfoFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'invalid_user_id' => InvalidUserIdFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'not_subscribed' => NotSubscribedFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'personal_team_operation_not_allowed' =>
        PersonalTeamOperationNotAllowedFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'personal_team_player_limit_exceeded' =>
        PersonalTeamPlayerLimitExceededFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'plan_expired' => PlanExpiredFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'player_birthday_missing' => PlayerBirthdayMissingFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'pitch_type_not_tagged_for_all_resources' =>
        PitchTypeNotTaggedForAllResourcesFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'player_throw_hand_missing' => PlayerThrowHandMissingFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'team_admin_absence' => TeamAdminAbsenceFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'team_plan_not_exists' => TeamPlanNotExistsFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'session_has_no_resources' => SessionHasNoResourcesFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'transaction_decoding_error' => TransactionDecodingErrorFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'unexpected_error_occurred' => UnexpectedErrorOccurredFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'user_already_exists' => UserAlreadyExistsFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'user_not_found' => UserNotFoundFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      'user_unavailable' => UserUnavailableFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
      // デフォルト: 汎用的な BadRequestFailure を返す
      _ => BadRequestFailure(
          code: code,
          status: status,
          description: description,
          underlyingException: underlyingException,
          stackTrace: stackTrace,
          title: title,
          response: response,
        ),
    };
  }
}

