class AICoachPromotionContainer extends ConsumerWidget {
  const AICoachPromotionContainer({super.key});

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final teamList = ref.watch(teamListControllerProvider);
    return teamList.when(
      error: (Object error, StackTrace stackTrace) => const SizedBox.shrink(),
      loading: () => const SizedBox.shrink(),
      data: (teams) {
        if (teams.hasLeft) return const SizedBox.shrink();
        final teamId = ref.read(profileStorageProvider).getTeamId();
        final team = teams.right.firstWhereOrNull((t) => t.id == teamId);
        // if (team != null &&
        //     team.isSingleUserTeam == true &&
        //     team.teamPlan?.isInAppleSubscription != true &&
        //     team.teamPlan?.isInStripeSubscription != true) {
        return Stack(
          children: [
            Container(
              decoration: BoxDecoration(
                borderRadius: BorderRadius.circular(8),
                color: ColorManager.main.withValues(alpha: 0.1),
                border: Border.all(color: ColorManager.main, width: 1.5),
              ),
              height: 48,
              width: double.infinity,
              padding: const EdgeInsets.only(left: 32),
              child: const Center(
                child: Text(
                  // '20球の解析達成でAIコーチが1回無料!',
                  'Get 1 Free AI Coach after 20 Analyses!',
                  style: TextStyle(fontWeight: FontWeight.w600),
                ),
              ),
            ),
            Positioned(
              left: 0,
              top: 0,
              bottom: 0,
              child: Container(
                width: 32,
                decoration: BoxDecoration(
                  color: ColorManager.main,
                  borderRadius: const BorderRadius.only(
                    topLeft: Radius.circular(8),
                    bottomLeft: Radius.circular(8),
                  ),
                ),
                child: const Icon(Icons.workspace_premium,
                    color: Colors.white, size: 20),
              ),
            ),
          ],
        );
        // } else {
        //   return const SizedBox.shrink();
        // }
      },
    );
  }
}
