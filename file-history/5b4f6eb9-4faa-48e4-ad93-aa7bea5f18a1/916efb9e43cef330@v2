import '../record_definitions.dart';

class ItemData {
  const ItemData({
    required this.id,
    required this.name,
    this.description,
    required this.isPaid,
    required this.isSubscription,
  });

  final String id;
  final String name;
  final String? description;
  final bool isPaid;
  final bool isSubscription;
}

class ItemBallData {
  const ItemBallData({
    required this.id,
    required this.itemId,
    required this.availableCount,
    required this.priority,
    this.validityPeriod,
  });

  final String id;
  final String itemId;
  final int availableCount;
  final int priority;
  final String? validityPeriod;
}

