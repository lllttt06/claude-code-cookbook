// 基本（デフォルトのプランあり）
@GenerateScenario()
Widget subscriptionPageDefaultPlan(BuildContext context) {
  return SubscriptionPage(
    currentPlan: PlanType.standard,
    team: _fakeTeam(id: 'team1'),
  );
}

// USA のストアフロントの場合（デフォルトのプランなし）
@GenerateScenario()
Widget storefrontUSAWithoutCurrentPlan(BuildContext context) {
  return ProviderScope(
    overrides: [
      storefrontProvider
          .overrideWith((ref) => Storefront(countryCode: 'USA', id: 'id')),
    ],
    child: SubscriptionPage(
      currentPlan: null,
      team: _fakeTeam(id: 'team1').copyWith(teamPlan: null),
    ),
  );
}

// USA のストアフロントの場合（デフォルトのプランあり）
@GenerateScenario()
Widget storefrontUSAWithCurrentPlan(BuildContext context) {
  return ProviderScope(
    overrides: [
      storefrontProvider
          .overrideWith((ref) => Storefront(countryCode: 'USA', id: 'id')),
    ],
    child: SubscriptionPage(
