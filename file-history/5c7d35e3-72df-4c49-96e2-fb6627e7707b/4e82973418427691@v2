## 後方互換性の対応

既存の getter を残して、内部で新しい getter を使用するラッパーを提供：

```typescript
/**
 * @deprecated Use teamPlanStatus instead
 */
get teamPlanAvailability(): {
  isAvailable: boolean;
  unavailableReason: TranslationKey | null;
} {
  const status = this.teamPlanStatus;
  const isAvailable = teamPlanStatusIsValid(status);

  let unavailableReason: TranslationKey | null = null;
  if (!isAvailable) {
    switch (status) {
      case TeamPlanStatus.EXPIRED:
        unavailableReason = 'team_plan_expired';
        break;
      case TeamPlanStatus.NO_CONTRACT:
        unavailableReason = 'no_team_plan_found';
        break;
      case TeamPlanStatus.NEXT_PLAN_PENDING:
        unavailableReason = 'next_team_plan_has_not_started_yet';
        break;
    }
  }

  return { isAvailable, unavailableReason };
}

/**
 * @deprecated Use canAnalyzeBall and ballUsageStatus instead
 */
get ballAvailability(): {
  isAvailable: boolean;
  unavailableReason: TranslationKey | null;
} {
  const canAnalyze = this.canAnalyzeBall;
  let unavailableReason: TranslationKey | null = null;

  if (!canAnalyze) {
    if (this.ballUsageStatus === BallUsageStatus.LIMIT_REACHED) {
      unavailableReason = 'you_have_reached_usage_limit';
    } else {
      unavailableReason = this.teamPlanAvailability.unavailableReason;
    }
  }

  return { isAvailable: canAnalyze, unavailableReason };
}
```

