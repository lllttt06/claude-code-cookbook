class _DropdownSettingDialog extends StatefulWidget {
  final int? index;
  final List<dynamic>? list;
  final String Function(dynamic) formatter;
  final void Function(dynamic) onChange;

  const _DropdownSettingDialog({
    required this.index,
    required this.list,
    required this.formatter,
    required this.onChange,
  });

  @override
  State<_DropdownSettingDialog> createState() => _DropdownSettingDialogState();

  static show(
      {required BuildContext context,
      required String title,
      required int? index,
      required List<dynamic>? list,
      required String Function(dynamic) formatter,
      required void Function(dynamic) onChange}) {
    showDialog(
      context: context,
      builder: (context) {
        return SimpleDialog(
          title: Text(title),
          children: <Widget>[
            _DropdownSettingDialog(
                index: index,
                list: list,
                formatter: formatter,
                onChange: onChange)
          ],
        );
      },
    );
  }
}

class _DropdownSettingDialogState extends State<_DropdownSettingDialog> {
  int? index;

  @override
  void initState() {
    super.initState();
    index = widget.index;
  }

  @override
  Widget build(BuildContext context) {
    return index != null && widget.list != null
        ? Container(
            padding: const EdgeInsets.all(15),
            child: Align(
              alignment: Alignment.topLeft,
              child: DropdownButton(
                isExpanded: true,
                value: widget.list![index!],
                icon: const Icon(Icons.arrow_drop_down_circle),
                items: widget.list!.map<DropdownMenuItem>((object) {
                  return DropdownMenuItem(
                    value: object,
                    child: Row(children: [
                      Text("${object.index}: "),
                      Text(widget.formatter(object))
                    ]),
                  );
                }).toList(),
                onChanged: (newValue) {
                  if (newValue != null) {
                    widget.onChange(newValue.index);
                    setState(() {
                      index = newValue.index;
                    });
                  }
                },
                hint: const Text("Select"),
              ),
            ),
          )
        : const Text("Notifiers not initialized.");
  }
}

_showLensDialog(BuildContext context, CameraController cameraController,
    CameraConfiguration cameraConfiguration) {
  _DropdownSettingDialog.show(
      context: context,
      title: "Lens",
      index: cameraConfiguration.lensIndex.value,
      list: cameraConfiguration.lensList.value,
      formatter: (lens) => lens.description,
      onChange: (newIndex) {
        cameraController.setLensIndex(newIndex);
      });
}

_showFormatDialog(BuildContext context, CameraController cameraController,
    CameraConfiguration cameraConfiguration) {
  _DropdownSettingDialog.show(
      context: context,
      title: "Format",
      index: cameraConfiguration.formatIndex.value,
      list: cameraConfiguration.formatList.value,
      formatter: (format) {
        final height = format.landscapeHeight;
        final width = format.landscapeWidth;
        final fps = format.fps;
        final fov = format.videoFieldOfView.toStringAsFixed(2);
        final options = <String>[];
        if (format.hdr) {
          options.add('hdr');
        }
        if (format.binned) {
          options.add('binned');
        }
        if (format.stabilization) {
          options.add('stbl.');
        }
        final description =
            "${height}x$width, ${fps}FPS\ndevice FoV $fov, ${options.join(', ')}";
        return description;
      },
      onChange: (newIndex) {
        cameraController.setFormatIndex(newIndex);
      });
}

class _ToggleSettingDialog extends StatefulWidget {
  final bool? value;
  final String falseLabel;
  final String trueLabel;
  final void Function(dynamic) onChange;

  const _ToggleSettingDialog({
    required this.value,
    required this.falseLabel,
    required this.trueLabel,
    required this.onChange,
  });

  @override
  State<_ToggleSettingDialog> createState() => _ToggleSettingDialogState();

  static show(
      {required BuildContext context,
      required String title,
      required bool? value,
      required String falseLabel,
      required String trueLabel,
      required void Function(dynamic) onChange}) {
    showDialog(
      context: context,
      builder: (context) {
        return SimpleDialog(
          title: Text(title),
          children: <Widget>[
            _ToggleSettingDialog(
                value: value,
                falseLabel: falseLabel,
                trueLabel: trueLabel,
                onChange: onChange)
          ],
        );
      },
    );
  }
}

class _ToggleSettingDialogState extends State<_ToggleSettingDialog> {
  bool? value;

  @override
  void initState() {
    super.initState();
    value = widget.value;
  }

  @override
  Widget build(BuildContext context) {
    return value != null
        ? Container(
            padding: const EdgeInsets.all(15),
            child: Row(children: [
              Text(widget.falseLabel),
              Switch(
                value: value!,
                onChanged: (newValue) {
                  widget.onChange(newValue);
                  setState(() {
                    value = newValue;
                  });
                },
              ),
              Text(widget.trueLabel),
            ]),
          )
        : const Text("Notifiers not initialized.");
  }
}

_showAFDialog(BuildContext context, CameraController cameraController,
    CameraConfiguration cameraConfiguration) {
  _ToggleSettingDialog.show(
      context: context,
      title: "Focus",
      value: cameraConfiguration.focusModeIsAuto.value,
      falseLabel: "Manual",
      trueLabel: "Auto",
      onChange: (newValue) {
        if (newValue) {
          cameraController.setFocusModeToAuto();
        } else {
          cameraController.setFocusModeToManual();
        }
      });
}

_showAutoExposureDialog(BuildContext context, CameraController cameraController,
    CameraConfiguration cameraConfiguration) {
  _ToggleSettingDialog.show(
    context: context,
    title: "Auto Exposure",
    value: cameraConfiguration.isAutoExposure.value,
    falseLabel: "Off",
    trueLabel: "On",
    onChange: (newValue) {
      if (newValue) {
        cameraController.setUpAutoExposureObserver();
      } else {
        cameraController.tearDownAutoExposureObserver();
      }
    },
  );
}

