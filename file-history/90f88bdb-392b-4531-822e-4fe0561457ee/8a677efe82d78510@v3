import { LockOutlined } from '@mui/icons-material';
import {
  Alert,
  Box,
  Button,
  Container,
  Paper,
  Stack,
  SxProps,
  Typography,
} from '@mui/material';

import { PAGE_INFO } from '@/constants/page.constants';
import useServicesHook from '@/hooks';
import { translate } from '@/utils/i18n';

export default function AccessDenied({ sx }: { sx?: SxProps }) {
  const { router } = useServicesHook();

  const handleGoBack = () => {
    router.back();
  };

  const handleGoHome = () => {
    router.push(PAGE_INFO.TOP.href());
  };

  return (
    <Container maxWidth="sm" sx={sx}>
      <Paper
        elevation={0}
        sx={{
          p: 6,
          textAlign: 'center',
          border: '1px solid',
          borderColor: 'divider',
        }}
      >
        <Stack spacing={3} alignItems="center">
          <Box
            sx={{
              width: 80,
              height: 80,
              borderRadius: '50%',
              backgroundColor: 'error.light',
              display: 'flex',
              alignItems: 'center',
              justifyContent: 'center',
            }}
          >
            <LockOutlined sx={{ fontSize: 48, color: 'error.main' }} />
          </Box>

          <Typography variant="h4" component="h1">
            {translate('access_denied')}
          </Typography>

          <Alert severity="error" sx={{ width: '100%' }}>
            {translate('insufficient_permission_for_page_access')}
          </Alert>

          <Typography variant="body1" color="text.secondary">
            {translate('contact_admin_for_access')}
          </Typography>

          <Stack direction={{ xs: 'column', sm: 'row' }} spacing={2}>
            <Button variant="outlined" onClick={handleGoBack}>
              {translate('go_back')}
            </Button>
            <Button variant="contained" onClick={handleGoHome}>
              {translate('go_to_home')}
            </Button>
          </Stack>
        </Stack>
      </Paper>
    </Container>
  );
}
